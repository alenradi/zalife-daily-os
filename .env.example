# ZaLife Daily OS 2.0 - environment configuration
# Copy this file to `.env` and fill in real values to enable integrations.

# ── Google OAuth (sign-in + Calendar sync) ──────────────────────────────
# Create at https://console.cloud.google.com/apis/credentials
# Type: OAuth 2.0 Web client
# Add your app URL under "Authorized JavaScript origins" (e.g. http://localhost:5173)
# Enable the Google Calendar API for the project.
# Leave empty to use the built-in demo Google flow.
VITE_GOOGLE_CLIENT_ID=

# ── Supabase (cloud database for all users) ─────────────────────────────
# Create a free project at https://supabase.com
# Run supabase/schema.sql in the SQL editor.
# Copy Project URL and publishable key from Supabase Settings → API Keys.
# Legacy anon JWT keys also work if your project still shows them.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ── AI Mentor (GPT-4o mini) ─────────────────────────────────────────────
# Server-side key — never expose in VITE_* vars. Works on Vercel and local dev
# (vite dev proxies POST /api/mentor using this key).
OPENAI_API_KEY=

# Optional custom mentor endpoint. Leave empty to use /api/mentor.
VITE_AI_ENDPOINT=

# ── Admin panel ─────────────────────────────────────────────────────────
# Passcode for /admin (Nadzorna Soba). Defaults to ZALIFE-ADMIN-2026 if unset.
VITE_ADMIN_CODE=
